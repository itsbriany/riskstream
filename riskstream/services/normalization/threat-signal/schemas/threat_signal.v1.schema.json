{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riskstream.local/schemas/threat_signal.v1.schema.json",
  "title": "RiskStream Threat Signal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "feed",
    "signal_kind",
    "action",
    "artifact_type",
    "artifact_value",
    "external_id",
    "raw_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "threat_signal.v1"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "feed": {
      "type": "string",
      "minLength": 1
    },
    "signal_kind": {
      "type": "string",
      "enum": ["indicator", "vulnerability"]
    },
    "action": {
      "type": "string",
      "enum": ["observed", "updated", "removed"]
    },
    "artifact_type": {
      "type": "string",
      "enum": ["url", "domain", "ip", "hash", "cve"]
    },
    "artifact_value": {
      "type": "string",
      "minLength": 1
    },
    "external_id": {
      "type": "string",
      "minLength": 1
    },
    "first_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "classification": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "reporter": {
      "type": "string",
      "minLength": 1
    },
    "evidence_url": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "raw_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "object_key", "row_number"],
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "object_key": {
          "type": "string",
          "minLength": 1
        },
        "row_number": {
          "type": "integer",
          "minimum": 1
        },
        "section": {
          "type": "string",
          "enum": ["added", "updated", "removed"]
        }
      }
    },
    "source_details": {
      "type": "object",
      "properties": {
        "threatfox": {
          "type": "object",
          "additionalProperties": true
        },
        "urlhaus": {
          "type": "object",
          "additionalProperties": true
        },
        "cisa-kev": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
